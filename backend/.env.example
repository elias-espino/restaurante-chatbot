# Base de datos MariaDB
DATABASE_URL="mysql://chatbot:chatbot_pass@localhost:3306/chatbot_db"

# JWT (cambia por strings aleatorios largos)
JWT_SECRET="pon-aqui-un-string-secreto-muy-largo-y-aleatorio"
JWT_REFRESH_SECRET="otro-string-secreto-diferente-para-refresh"

# Gemini IA
GEMINI_API_KEY="tu-api-key-de-google-ai-studio"

# Superadmin (módulo /api/admin)
ADMIN_EMAIL="superadmin@chatbox.com"
ADMIN_PASSWORD="cambia-esta-password-segura"
ADMIN_JWT_SECRET="otro-string-secreto-exclusivo-para-admin"

# Servidor
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

LOG_LEVEL=info
