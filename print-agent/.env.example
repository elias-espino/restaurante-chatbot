# ══════════════════════════════════════════════════════════════
#  Print Agent — Configuración  (Windows)
# ══════════════════════════════════════════════════════════════

# URL del backend (en producción, la URL de tu servidor)
BACKEND_URL=http://localhost:3000

# Token del agente — cópialo desde Backoffice > Configuración > Impresoras
AGENT_TOKEN=pega-aqui-el-agent-token

# ──────────────────────────────────────────────────────────────
#  TIPO DE IMPRESORA
#  USB     → impresora conectada por cable USB (recomendado para fijo)
#  NETWORK → impresora con IP en la red local (Ethernet o WiFi)
#  SERIAL  → impresora Bluetooth emparejada como puerto COM (PT-210)
#  SPOOLER → impresora instalada en Windows (cola del SO, modo RAW)
# ──────────────────────────────────────────────────────────────
PRINTER_TYPE=SERIAL

# ══════════════════════════════════════════════════════════════
#  PT-210 BLUETOOTH — Setup en Windows
#
#  1. Encender la PT-210:
#       Mantén presionado el botón FEED ~3 segundos
#       El LED azul parpadeará (modo emparejamiento)
#
#  2. Emparejar en Windows:
#       Configuración > Bluetooth y dispositivos > Agregar dispositivo
#       Selecciona "PT-210" o "MTP-II"
#
#  3. Encontrar el puerto COM:
#       Administrador de dispositivos > Puertos (COM y LPT)
#       Busca: "Standard Serial over Bluetooth link (COMx)"
#       Ese COMx es el valor para SERIAL_PORT
#       (también puedes ejecutar: npm run list-ports)
#
#  4. Configura las variables de abajo:
# ══════════════════════════════════════════════════════════════
SERIAL_PORT=COM5
SERIAL_BAUD=9600

# ── Solo para PRINTER_TYPE=NETWORK ────────────────────────────
# PRINTER_HOST=192.168.1.100
# PRINTER_PORT=9100

# ── Solo para PRINTER_TYPE=SPOOLER ────────────────────────────
# Nombre EXACTO como aparece en "Dispositivos e impresoras" de Windows
# (ejecuta npm run list-ports para verlo)
# SPOOLER_PRINTER_NAME=PT-210

# ──────────────────────────────────────────────────────────────
#  PAPEL Y CODIFICACIÓN
# ──────────────────────────────────────────────────────────────
# Ancho del papel: 32 = rollo de 58mm  |  42 = rollo de 80mm
PAPER_WIDTH=32

# Codificación de texto. CP437 funciona en la PT-210 para español (acentos, ñ).
# No cambiar a menos que los caracteres salgan mal.
ENCODING=CP437

# ──────────────────────────────────────────────────────────────
#  ENCABEZADO DEL TICKET
# ──────────────────────────────────────────────────────────────
RESTAURANT_NAME=MI RESTAURANTE
RESTAURANT_ADDRESS=Calle Principal 123
RESTAURANT_PHONE=Tel: 555-1234

# Nivel de log: error | warn | info | debug
LOG_LEVEL=info
