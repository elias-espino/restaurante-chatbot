# URL del backend (en producción, la URL de tu servidor)
BACKEND_URL=http://localhost:3000

# Token del agente (cópialo desde el backoffice > Configuración > Impresoras)
AGENT_TOKEN=pega-aqui-el-agent-token

# Tipo de impresora: USB | NETWORK | SERIAL | SPOOLER
#   USB      → escpos-usb (libusb)               — Win/Mac/Linux
#   NETWORK  → TCP/IP puerto 9100 (Ethernet/WiFi) — Win/Mac/Linux
#   SERIAL   → puerto serie o COM virtual de Bluetooth (PT-210, MTP-II, etc.)
#   SPOOLER  → cola del SO en modo RAW (winspool en Win, CUPS en Mac/Linux)
PRINTER_TYPE=USB

# ── Solo para NETWORK ───────────────────────────────────────────────
# PRINTER_HOST=192.168.1.100
# PRINTER_PORT=9100

# ── Solo para SERIAL (Bluetooth emparejado / RS-232) ────────────────
# Windows: el COM virtual que asigna el SO al emparejar la impresora BT
#          (revisar en "Administrador de dispositivos > Puertos COM y LPT")
# macOS:   /dev/cu.NombreImpresora-SPP   (preferido sobre /dev/tty.*)
# Linux:   /dev/rfcomm0  (tras `rfcomm bind`)
#
# Tip: si pones "auto", el agente intenta detectar el puerto BT solo.
#      Útil sobre todo en macOS donde el path varía por dispositivo.
#      Para diagnóstico ejecuta: npm run list-ports
# SERIAL_PORT=auto
# SERIAL_BAUD=9600

# ── Solo para SPOOLER (cola del SO, RAW) ────────────────────────────
# Nombre EXACTO de la impresora tal como aparece en:
#   Windows: "Dispositivos e impresoras"
#   macOS:   `lpstat -p`  o "Preferencias del Sistema > Impresoras"
#   Linux:   `lpstat -p`
# SPOOLER_PRINTER_NAME=PT-210

# Ancho del papel: 32 para 58mm, 42 para 80mm
PAPER_WIDTH=32

# Codificación del texto. CP437 funciona en la mayoría de térmicas occidentales.
# Si tu impresora soporta UTF-8 nativo, ponlo aquí.
# PT-210 / MTP-II vienen por defecto en GBK; déjalo en CP437 para acentos español.
ENCODING=CP437

# Info del encabezado del ticket
RESTAURANT_NAME=MI RESTAURANTE
RESTAURANT_ADDRESS=Calle Principal 123
RESTAURANT_PHONE=Tel: 555-1234

LOG_LEVEL=info
